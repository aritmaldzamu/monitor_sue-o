            <layout class="QVBoxLayout"><property name="leftMargin"><number>22</number></property><property name="topMargin"><number>22</number></property><property name="rightMargin"><number>22</number></property><property name="bottomMargin"><number>22</number></property><property name="spacing"><number>14</number></property>
             <item><widget class="QLabel"><property name="text"><string>RANGOS IDEALES</string></property><property name="role" stdset="0"><string>cardTitle</string></property></widget></item>
             <item><layout class="QFormLayout"><property name="horizontalSpacing"><number>16</number></property><property name="verticalSpacing"><number>10</number></property>
              <item row="0" column="0"><widget class="QLabel"><property name="text"><string>Temp mín (°C)</string></property></widget></item>
              <item row="0" column="1"><widget class="QDoubleSpinBox" name="spnTempMin"><property name="value"><double>18.0</double></property></widget></item>
              <item row="1" column="0"><widget class="QLabel"><property name="text"><string>Temp máx (°C)</string></property></widget></item>
