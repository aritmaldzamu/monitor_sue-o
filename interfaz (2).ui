      <!-- ============ PAGE 2 · CONFIGURACIÓN ============ -->
      <widget class="QWidget" name="pageConfig">
       <layout class="QVBoxLayout" name="cfgLayout">
        <property name="leftMargin"><number>28</number></property><property name="topMargin"><number>24</number></property>
        <property name="rightMargin"><number>28</number></property><property name="bottomMargin"><number>24</number></property>
        <property name="spacing"><number>22</number></property>

        <item>
         <layout class="QVBoxLayout"><property name="spacing"><number>4</number></property>
          <item><widget class="QLabel" name="lblCfgTitle"><property name="text"><string>Configuración</string></property><property name="role" stdset="0"><string>pageH1</string></property></widget></item>
          <item><widget class="QLabel" name="lblCfgSub"><property name="text"><string>Ajusta rangos ideales, intervalos de muestreo y destino de datos</string></property><property name="role" stdset="0"><string>pageSub</string></property></widget></item>
         </layout>
        </item>

        <item>
         <layout class="QHBoxLayout" name="cfgRow"><property name="spacing"><number>22</number></property>

          <!-- Captura -->
          <item>
           <widget class="QFrame" name="cfgCaptura"><property name="role" stdset="0"><string>page-card</string></property>
            <layout class="QVBoxLayout"><property name="leftMargin"><number>22</number></property><property name="topMargin"><number>22</number></property><property name="rightMargin"><number>22</number></property><property name="bottomMargin"><number>22</number></property><property name="spacing"><number>14</number></property>
             <item><widget class="QLabel"><property name="text"><string>CAPTURA</string></property><property name="role" stdset="0"><string>cardTitle</string></property></widget></item>
             <item><layout class="QFormLayout"><property name="horizontalSpacing"><number>16</number></property><property name="verticalSpacing"><number>10</number></property>
              <item row="0" column="0"><widget class="QLabel"><property name="text"><string>Intervalo (s)</string></property></widget></item>
              <item row="0" column="1"><widget class="QSpinBox" name="spnIntervalo"><property name="minimum"><number>1</number></property><property name="maximum"><number>120</number></property><property name="value"><number>5</number></property></widget></item>
              <item row="1" column="0"><widget class="QLabel"><property name="text"><string>Total lecturas</string></property></widget></item>
              <item row="1" column="1"><widget class="QSpinBox" name="spnTotal"><property name="minimum"><number>10</number></property><property name="maximum"><number>100000</number></property><property name="value"><number>360</number></property></widget></item>
              <item row="2" column="0"><widget class="QLabel"><property name="text"><string>Hora de inicio</string></property></widget></item>
              <item row="2" column="1"><widget class="QLineEdit" name="txtInicio"><property name="text"><string>23:00</string></property></widget></item>
              <item row="3" column="0"><widget class="QLabel"><property name="text"><string>Auto-iniciar</string></property></widget></item>
              <item row="3" column="1"><widget class="QCheckBox" name="chkAutoStart"><property name="text"><string>al detectar oscuridad</string></property><property name="checked"><bool>true</bool></property></widget></item>
             </layout></item>
            </layout>
           </widget>
          </item>

          <!-- Rangos -->
