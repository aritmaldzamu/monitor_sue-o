<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry"><rect><x>0</x><y>0</y><width>1600</width><height>960</height></rect></property>
  <property name="minimumSize"><size><width>1280</width><height>800</height></size></property>
  <property name="windowTitle"><string>Somnus · Monitor de Calidad de Sueño</string></property>
  <property name="styleSheet">
   <string notr="true">
QMainWindow, QWidget#centralWidget { background: #0b0b0c; color: #ededf0; font-family: &quot;SF Pro Display&quot;, &quot;SF Pro Text&quot;, &quot;-apple-system&quot;, &quot;BlinkMacSystemFont&quot;, &quot;Segoe UI&quot;, sans-serif; }
QFrame#cardHero, QFrame#cardTemp, QFrame#cardHum, QFrame#cardLux, QFrame#cardMov, QFrame#cardChart, QFrame[role=&quot;page-card&quot;] {
    background: #131315; border: 1px solid #242428; border-radius: 20px;
}
QFrame#topBar { background: #0b0b0c; border: none; border-bottom: 1px solid #242428; }
QLabel#brandMark { background: #ededf0; color: #0b0b0c; font-size: 20px; font-weight: 600; border-radius: 10px; min-width:38px;min-height:38px;max-width:38px;max-height:38px; qproperty-alignment: AlignCenter; }
QLabel#brandName { font-size: 17px; font-weight: 600; color: #ededf0; letter-spacing: -0.3px; }
QLabel#brandSub { font-size: 10px; color: #8a8a93; letter-spacing: 1.2px; font-weight: 600; }
QFrame#navBar { background: #141416; border: 1px solid #242428; border-radius: 20px; }
QPushButton[nav=&quot;true&quot;] { background: transparent; color: #8a8a93; border: none; padding: 8px 18px; border-radius: 16px; font-size: 13px; font-weight: 500; }
QPushButton[nav=&quot;true&quot;]:hover { color: #ededf0; }
QPushButton[nav=&quot;true&quot;][active=&quot;true&quot;] { background: #ededf0; color: #0b0b0c; font-weight: 600; }
QLabel#clockLbl { font-size: 13px; color: #c7c7cc; font-weight: 500; }
QFrame#statusPill { background: transparent; border: 1px solid #242428; border-radius: 14px; }
QLabel#statusDot { background: #b8f2b8; border-radius: 4px; min-width:8px;max-width:8px;min-height:8px;max-height:8px; }
QLabel#statusText { color: #c7c7cc; font-size: 12px; font-weight: 500; }
QLabel#avatarLbl { background: #1a1a1d; color: #c7c7cc; border: 1px solid #2e2e34; border-radius: 18px; min-width:36px;max-width:36px;min-height:36px;max-height:36px; font-size: 12px; font-weight: 600; qproperty-alignment: AlignCenter; }
QLabel[role=&quot;cardTitle&quot;] { font-size: 11px; color: #8a8a93; letter-spacing: 1.6px; font-weight: 600; }
QLabel[role=&quot;cardSub&quot;] { font-size: 11px; color: #5a5a62; }
QLabel[role=&quot;badge&quot;] { font-size: 10px; color: #cfcfd5; font-weight: 600; letter-spacing: 0.8px; border: 1px solid #4a4a52; border-radius: 10px; padding: 3px 10px; }
QLabel[role=&quot;badgeWarn&quot;] { font-size: 10px; color: #e6d28e; font-weight: 600; letter-spacing: 0.8px; border: 1px solid #5a4f2a; background: #1f1c10; border-radius: 10px; padding: 3px 10px; }
QLabel[role=&quot;value&quot;] { font-size: 52px; color: #ededf0; font-weight: 300; letter-spacing: -1.8px; }
QLabel[role=&quot;unit&quot;] { font-size: 16px; color: #8a8a93; }
QLabel[role=&quot;numBig&quot;] { font-size: 44px; color: #ededf0; font-weight: 300; letter-spacing: -1.4px; }
QLabel[role=&quot;pageH1&quot;] { font-size: 36px; color: #ededf0; font-weight: 300; letter-spacing: -1.2px; }
QLabel[role=&quot;pageSub&quot;] { font-size: 13px; color: #8a8a93; font-weight: 400; }
QFrame[role=&quot;chip&quot;] { background: #141416; border: 1px solid #242428; border-radius: 14px; }
QLabel[role=&quot;chipText&quot;] { font-size: 12px; color: #c7c7cc; font-weight: 500; }
QLabel[role=&quot;chipDot&quot;] { background: #b8f2b8; border-radius: 4px; min-width:8px;max-width:8px;min-height:8px;max-height:8px; }
QPushButton[variant=&quot;ghost&quot;] { background: #18181b; color: #c7c7cc; border: 1px solid #2e2e34; border-radius: 10px; padding: 9px 14px; font-size: 12px; font-weight: 500; }
QPushButton[variant=&quot;ghost&quot;]:hover { border: 1px solid #4a4a52; color: #ededf0; }
QPushButton[variant=&quot;primary&quot;] { background: #ededf0; color: #0b0b0c; border: 1px solid #ededf0; border-radius: 10px; padding: 12px 16px; font-size: 12px; font-weight: 600; }
QPushButton[variant=&quot;primary&quot;]:hover { background: #ffffff; }
QFrame[role=&quot;sep&quot;] { background: transparent; border: none; border-top: 1px dashed #2e2e34; }
QLabel[role=&quot;actLabel&quot;] { font-size: 10px; color: #5a5a62; letter-spacing: 1.4px; font-weight: 600; }
QFrame#chartArea, QFrame[role=&quot;plotArea&quot;] { background: #0e0e10; border: 1px solid #1f1f22; border-radius: 12px; }
QLabel[role=&quot;placeholder&quot;] { color: #5a5a62; font-size: 11px; font-weight: 500; qproperty-alignment: AlignCenter; }
QWidget#scoreRing { background: transparent; }
QWidget[role=&quot;miniBars&quot;] { background: transparent; }

/* config form */
QLineEdit, QSpinBox, QDoubleSpinBox, QComboBox { background:#18181b; color:#ededf0; border:1px solid #2e2e34; border-radius:8px; padding:8px 10px; font-size:13px; }
QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QComboBox:focus { border:1px solid #ededf0; }
QCheckBox { color:#c7c7cc; font-size:12px; spacing:8px; }
QCheckBox::indicator { width:16px; height:16px; border:1px solid #4a4a52; border-radius:4px; background:#18181b; }
QCheckBox::indicator:checked { background:#ededf0; border:1px solid #ededf0; }

/* table */
QTableWidget { background:#0e0e10; color:#ededf0; border:1px solid #1f1f22; border-radius:12px; gridline-color:#1f1f22; font-size:12px; }
QTableWidget::item { padding:8px; }
QTableWidget::item:selected { background:#1f1f22; color:#ededf0; }
QHeaderView::section { background:#131315; color:#8a8a93; border:none; border-bottom:1px solid #242428; padding:8px; font-size:10px; font-weight:600; letter-spacing:1.2px; }

QScrollBar:vertical { background: #131315; width: 8px; }
QScrollBar::handle:vertical { background: #2e2e34; border-radius: 4px; }
   </string>
